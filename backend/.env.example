# ── LLM Provider ─────────────────────────────────────────────────────────────
# Which LLM provider to use by default: "gemini" (recommended) or "qwen"
DEFAULT_MODEL=gemini

# Google Gemini — get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Alibaba Qwen via DashScope — get a key at https://dashscope-intl.aliyuncs.com
QWEN_API_KEY=your_qwen_api_key_here

# ── PostgreSQL Database ───────────────────────────────────────────────────────
DATABASE_URl=postgresql://postgres:yourpassword@localhost:5432/ai_content_studio

# ── JWT Auth ──────────────────────────────────────────────────────────────────
SECRET_KEY_FOR_LOGIN=generate_a_random_64_char_hex_string
ALGORITHM=HS256

# ── Session middleware ────────────────────────────────────────────────────────
SECRET_KEY=generate_another_random_secret_string

# ── Google OAuth (for login + YouTube) ───────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── YouTube OAuth redirect ────────────────────────────────────────────────────
YOUTUBE_REDIRECT_URI=http://localhost:8000/youtube/callback

# ── MongoDB (creator memory layer) ───────────────────────────────────────────
# Get a free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/
MONGODB_DB_NAME=ai_content_studio
MONGODB_MCP_URL=

# ── Elasticsearch (trend intelligence layer) ──────────────────────────────────
# Leave empty to disable trend intelligence
ELASTICSEARCH_URL=
ELASTICSEARCH_API_KEY=
ELASTIC_MCP_URL=
