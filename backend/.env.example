# AI model API keys
GEMINI_API_KEY=your_gemini_api_key_here
QWEN_API_KEY=your_qwen_api_key_here

# PostgreSQL Database
DATABASE_URl=postgresql://postgres:yourpassword@localhost:5432/ai_content_studio

# JWT Auth
SECRET_KEY_FOR_LOGIN=generate_a_random_64_char_hex_string
ALGORITHM=HS256

# Session middleware secret
SECRET_KEY=generate_another_random_secret_string

# Google OAuth (for Google login + YouTube connect)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# YouTube OAuth redirect
YOUTUBE_REDIRECT_URI=http://localhost:8000/youtube/callback